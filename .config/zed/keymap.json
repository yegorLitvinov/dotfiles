// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-shift-g": "git_panel::ToggleFocus",
      "cmd-shift-a": "outline_panel::ToggleFocus",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-shift-g": "git_panel::ToggleFocus",
      "cmd-shift-a": "outline_panel::ToggleFocus",
      "ctrl-n": "search::SelectNextMatch",
      "ctrl-shift-n": "search::SelectPreviousMatch",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "alt-cmd-b": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-cmd-b": "git::Branch"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-cmd-b": "git::Branch"
    }
  }
]
